{
  "extends": ["stylelint-config-standard-scss"],
  "rules": {
    "at-rule-no-unknown": null,
    "scss/at-rule-no-unknown": [true],
    "color-named": "never",
    "color-hex-length": "long",
    "function-disallowed-list": ["rgb"],
    "declaration-block-no-duplicate-properties": [
      true,
      {
        "ignore": ["consecutive-duplicates-with-different-values"]
      }
    ],
    "declaration-empty-line-before": null,
    "declaration-property-unit-allowed-list": {
      "/^border(?!.*-radius$)/": ["px", "%"],
      "/^border-radius/": ["px", "rem", "%"],
      "/^box-shadow": ["px"],
      "/^margin/": ["rem", "px"],
      "/^padding/": ["rem", "px", "vw"],
      "font-size": ["rem", "em", "vw"],
      "height": ["rem", "%", "vh", "px", "dvh"],
      "width": ["rem", "%", "vw", "px"]
    },
    "no-duplicate-selectors": true,
    "scss/dollar-variable-pattern": "^[a-z\\d](?:[a-z\\d]|-(?=[a-z\\d]))*$",
    "scss/selector-no-redundant-nesting-selector": true,
    "selector-class-pattern": [
      "^[a-z0-9-]+(__[a-z0-9-]+)?(--[a-z0-9-]+)?$",
      {
        "message": "Please follow BEM naming conventions",
        "resolveNestedSelectors": true
      }
    ],
    "selector-max-id": [1],
    "value-no-vendor-prefix": true,
    "font-family-no-missing-generic-family-keyword": null,
    "no-descending-specificity": null,
    "selector-pseudo-class-no-unknown": [
      true,
      {
        "ignorePseudoClasses": ["global"]
      }
    ],
    "scss/comment-no-empty": null,
    "scss/double-slash-comment-empty-line-before": null,
    "scss/at-extend-no-missing-placeholder": null,
    "no-invalid-position-at-import-rule": null,
    "rule-empty-line-before": null,
    "selector-no-vendor-prefix": null,
    "alpha-value-notation": null,
    "color-function-notation": null,
    "scss/no-global-function-names": null,
    "value-keyword-case": null,
    "shorthand-property-no-redundant-values": null,
    "scss/operator-no-unspaced": null,
    "declaration-block-no-redundant-longhand-properties": null,
    "keyframes-name-pattern": null,
    "number-max-precision": null,
    "scss/dollar-variable-empty-line-before": null,
    "property-no-vendor-prefix": null,
    "media-query-no-invalid": null,
    "max-nesting-depth": [2, { "ignore": ["pseudo-classes"] }],
    "declaration-block-single-line-max-declarations": null,
    "selector-max-compound-selectors": 2,
    "selector-max-specificity": null,
    "block-no-empty": true,
    "color-no-invalid-hex": true,
    "declaration-block-no-shorthand-property-overrides": true,
    "unit-disallowed-list": [
      ["px"],
      {
        "ignoreProperties": {
          "px": ["border", "box-shadow", "/^--/", "margin", "padding"]
        }
      }
    ],

    "property-no-unknown": [
      true,
      {
        "ignoreProperties": ["composes"]
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/*.css"],
      "rules": {
        "selector-max-specificity": "0,3,0"
      }
    }
  ]
}
